{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "nifgati.co.il" }],
      "destination": "https://www.nifgati.co.il/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/api/claude",    "destination": "/api/claude.js" },
    { "source": "/api/notify",    "destination": "/api/notify.js" },
    { "source": "/privacy",       "destination": "/index.html" },
    { "source": "/accessibility", "destination": "/index.html" },
    { "source": "/taonat-drakhim","destination": "/index.html" },
    { "source": "/ofanoa",        "destination": "/index.html" },
    { "source": "/avoda",         "destination": "/index.html" },
    { "source": "/korkinet",      "destination": "/index.html" },
    { "source": "/holeh-regel",   "destination": "/index.html" },
    { "source": "/tzlipat-shot",  "destination": "/index.html" },
    { "source": "/pritzat-disc",  "destination": "/index.html" },
    { "source": "/shever",        "destination": "/index.html" },
    { "source": "/ptsd",          "destination": "/index.html" },
    { "source": "/machshevon",    "destination": "/index.html" },
    { "source": "/nechut",        "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",     "value": "camera=(), microphone=(self), geolocation=()" }
      ]
    }
  ]
}
